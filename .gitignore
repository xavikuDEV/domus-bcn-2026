# --- SEGURIDAD (Archivos sensibles) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# --- DEPENDENCIAS ---
/node_modules
/.pnp
.pnp.*

# --- NEXT.JS Y COMPILACIÓN ---
/.next/
/out/
/build
*.tsbuildinfo
next-env.d.ts

# --- TESTING ---
/coverage
__snapshots__/
.vitest

# --- IDEs Y HERRAMIENTAS ---
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/settings.json
.idea/
.DS_Store

# --- LOGS Y DEBUG ---
*.log
npm-debug.log*
logs/

# --- VERCEL ---
.vercel

